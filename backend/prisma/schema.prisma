generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  name          String?
  passwordHash  String?
  provider      String             @default("email")
  role          String             @default("user")
  tier          String             @default("free")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  analyses      Analysis[]
  resumes       Resume[]
  coverLetters  CoverLetter[]
  interviews    InterviewSession[]
  batchJobs     BatchJob[]
  apiKeys       ApiKey[]
  notifications Notification[]
}

model Resume {
  id            String          @id @default(cuid())
  userId        String?
  originalName  String
  mimeType      String
  sizeBytes     Int
  storagePath   String?
  extractedText String?         @db.Text
  createdAt     DateTime        @default(now())
  analyses      Analysis[]
  user          User?           @relation(fields: [userId], references: [id])
  versions      ResumeVersion[]
}

model ResumeVersion {
  id            String   @id @default(cuid())
  resumeId      String
  versionNum    Int
  label         String?
  extractedText String?  @db.Text
  score         Int?
  domain        String?
  createdAt     DateTime @default(now())
  resume        Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

model Analysis {
  id              String   @id @default(cuid())
  userId          String?
  resumeId        String
  mode            String
  domain          String
  score           Int?
  keywordsMatched String[]
  keywordsMissed  String[]
  suggestions     String[]
  warnings        String[]
  breakdown       Json?
  keywordGap      Json?
  rewrittenText   String?  @db.Text
  jobDescription  String?  @db.Text
  emailSent       Boolean  @default(false)
  processingMs    Int?
  createdAt       DateTime @default(now())
  user            User?    @relation(fields: [userId], references: [id])
  resume          Resume   @relation(fields: [resumeId], references: [id])

  @@index([userId])
  @@index([domain])
  @@index([createdAt])
}

model CoverLetter {
  id             String   @id @default(cuid())
  userId         String?
  resumeText     String   @db.Text
  jobDescription String   @db.Text
  companyName    String?
  role           String?
  generatedText  String   @db.Text
  tone           String   @default("professional")
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model InterviewSession {
  id             String   @id @default(cuid())
  userId         String?
  resumeText     String   @db.Text
  jobDescription String   @db.Text
  domain         String
  questions      Json
  difficulty     String   @default("medium")
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model BatchJob {
  id           String   @id @default(cuid())
  userId       String?
  status       String   @default("pending")
  totalJDs     Int
  completedJDs Int      @default(0)
  results      Json?
  domain       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  key        String    @unique
  name       String
  usageCount Int       @default(0)
  lastUsed   DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}
