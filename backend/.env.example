# ─────────────────────────────────────────────────────────────
#  ATS Analyzer Backend — Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ats_analyzer"

# ── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── AI ──────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"

# ── App ─────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# ── File Upload ──────────────────────────────────────────────
MAX_FILE_SIZE_MB=5

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/v1/users/google/callback"

# ── OpenTelemetry (optional) ─────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME="ats-analyzer-backend"
OTEL_EXPORTER_JAEGER_ENDPOINT="http://localhost:14268/api/traces"

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL="info"
